{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "typeRoots": ["../marketplace/node_modules/@types"],
    "paths": {
      "@sancus/marketplace": ["../marketplace/dist/index.d.ts"],
      "@sancus/marketplace/*": ["../marketplace/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
